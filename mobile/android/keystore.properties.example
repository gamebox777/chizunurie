# リリース署名（アップロードキー）の設定テンプレート。
# このファイルを keystore.properties にコピーし、keytool で作った鍵に合わせて値を埋める。
# keystore.properties 本体と *.jks は .gitignore 済み（コミット禁止）。
#
#   cp keystore.properties.example keystore.properties
#
# storeFile はリポジトリ root（mobile/android）からの相対パス。
storeFile=upload-keystore.jks
storePassword=ここにストアのパスワード
keyAlias=upload
keyPassword=ここに鍵のパスワード
