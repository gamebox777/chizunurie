{
  "name": "chizunurie-scripts",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "docker compose up -d db",
    "dev": "concurrently -n frontend,backend,studio -c cyan,yellow,magenta \"npm run dev:frontend\" \"npm run dev:backend\" \"npm run dev:studio\"",
    "dev:local": "bash scripts/start.sh local",
    "dev:docker": "bash scripts/start.sh docker",
    "stop": "bash scripts/start.sh stop",
    "dev:frontend": "npm run dev --prefix frontend",
    "dev:backend": "npm run dev --prefix backend",
    "dev:studio": "npm run db:studio --prefix backend",
    "build": "npm run build --prefix frontend",
    "start": "npm run start --prefix frontend",
    "fetch-chocho": "node scripts/fetch-chocho.mjs",
    "build-mesh": "node --max-old-space-size=8192 scripts/build-mesh.mjs",
    "build-muni-stats": "node --max-old-space-size=8192 scripts/build-muni-stats.mjs",
    "build-muni-kana": "node scripts/build-muni-kana.mjs",
    "build-world-land": "node scripts/build-world-land.mjs",
    "build-world": "node --max-old-space-size=8192 scripts/build-world.mjs",
    "build-world-stats": "node --max-old-space-size=8192 scripts/build-world-stats.mjs",
    "build-pmtiles": "node --max-old-space-size=8192 scripts/build-pmtiles.mjs"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  },
  "dependencies": {
    "@mapbox/vector-tile": "^2.0.4",
    "better-sqlite3": "^12.10.0",
    "geojson-vt": "^4.0.3",
    "pbf": "^4.0.1",
    "vt-pbf": "^3.1.3"
  }
}
