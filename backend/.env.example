# PostgreSQL（docker compose up で起動したDBに接続）
DATABASE_URL=postgresql://postgres:devpassword@localhost:5432/chizunurie

# better-auth（openssl rand -hex 32 で生成）
BETTER_AUTH_SECRET=changeme
BETTER_AUTH_URL=http://localhost:3001

# フロントエンドのURL（CORS許可）
FRONTEND_URL=http://localhost:3000

# Google OAuth（GCP コンソールで取得: APIs & Services > Credentials）
# 承認済みリダイレクトURI: http://localhost:3001/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
