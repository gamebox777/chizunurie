# ── 本番（Coolify）用のバックエンド環境変数のサンプル ────────────────
# 実際の値は Coolify の各サービスの Environment Variables に設定する。
# このファイル自体はコミットしてよい（値はダミー）。

# PostgreSQL（同じ VPS 上の Coolify Postgres へ Docker 内部ネットワークで接続）
# 例: postgres://<user>:<password>@<内部ホスト名>:5432/<db>
# Coolify の Postgres は外部公開せず、内部接続文字列を使う。
DATABASE_URL=postgres://chizunurie:CHANGE_ME@chizunurie-postgres:5432/chizunurie

# better-auth
# SECRET は `openssl rand -base64 32` などで本番用に新しく生成する（開発用と分ける）
BETTER_AUTH_SECRET=GENERATE_A_NEW_RANDOM_SECRET
# 公開ドメイン（フロントと同一。プロキシ越しに /api/auth が解決される）
BETTER_AUTH_URL=https://chizunurie.example.com

# フロントエンドの公開URL（CORS 許可 & trustedOrigins。BETTER_AUTH_URL と同じ）
FRONTEND_URL=https://chizunurie.example.com

# Google OAuth（開発と同じ ID/Secret を使う）
# Google Cloud Console の「承認済みのリダイレクト URI」に本番URLを追加すること:
#   https://chizunurie.example.com/api/auth/callback/google
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET

# 待ち受けポート（Dockerfile の EXPOSE と合わせる）
PORT=3001
